MERGE (:ClimateCondition {entity_id:'KG-CLI-005', name_cn:'温暖', range:'20-25°C', description:'多数害虫适温区，取食繁殖活跃'});
MERGE (:ClimateCondition {entity_id:'KG-CLI-006', name_cn:'低温', range:'<5°C', description:'抑制多数病虫害活动'});

