MERGE (:GrowthCycle {entity_id:'KG-GC-002', stage_name:'展叶期', time_range:'4月中旬-5月上旬', description:'叶片迅速展开，新梢旺盛生长', order:2});
MERGE (:GrowthCycle {entity_id:'KG-GC-003', stage_name:'花期', time_range:'5月中旬-6月下旬', description:'开花授粉，花量大花期长', order:3});
MERGE (:GrowthCycle {entity_id:'KG-GC-004', stage_name:'幼果期', time_range:'6月下旬-7月中旬', description:'坐果后快速分裂期，对病虫害敏感', order:4});
