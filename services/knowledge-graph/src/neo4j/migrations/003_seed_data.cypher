MATCH (a:PestDisease {entity_id:'KG-ENT-014'}), (b:PestDisease {entity_id:'KG-ENT-017'}) MERGE (a)-[:SIMILAR_TO {differentiation:'红蜘蛛与日灼，红蜘蛛致叶脱落增加果实日灼风险'}]->(b);
MATCH (a:PestDisease {entity_id:'KG-ENT-018'}), (b:PestDisease {entity_id:'KG-ENT-031'}) MERGE (a)-[:SIMILAR_TO {differentiation:'黄叶病与灰斑病均可致叶片失绿，黄叶病缺铁灰斑病侵染'}]->(b);
MATCH (a:PestDisease {entity_id:'KG-ENT-019'}), (b:PestDisease {entity_id:'KG-ENT-021'}) MERGE (a)-[:SIMILAR_TO {differentiation:'根朽病与干腐病均可致树势衰弱，根朽病从根干腐病从干'}]->(b);
MATCH (a:PestDisease {entity_id:'KG-ENT-020'}), (b:PestDisease {entity_id:'KG-ENT-031'}) MERGE (a)-[:SIMILAR_TO {differentiation:'花叶病与灰斑病均致叶面斑驳，花叶病毒灰斑真菌'}]->(b);

