MERGE (:PestDisease {entity_id:'KG-ENT-001', name_cn:'枣炭疽病', scientific_name:'Colletotrichum gloeosporioides', category:'病害', description:'由胶孢炭疽菌引起主要为害果实也能侵染叶片和嫩枝。果实上出现圆形或不规则形褐色病斑后期凹陷产生同心轮纹状黑色小点。高温高湿利于发病。'});
MERGE (:PestDisease {entity_id:'KG-ENT-002', name_cn:'枣疯病', scientific_name:'Candidatus Phytoplasma ziziphi', category:'病害', description:'由植原体引起表现为丛枝花叶花变叶等症状。病原通过嫁接和叶蝉传播。最严重时整株枯死是枣树毁灭性病害。'});
MERGE (:PestDisease {entity_id:'KG-ENT-003', name_cn:'枣树锈病', scientific_name:'Phakopsora ziziphi-vulgaris', category:'病害', description:'由枣层锈菌引起主要为害叶片。叶背产生黄褐色夏孢子堆叶正面出现褪绿小斑点。高温高湿利于发病。'});
MERGE (:PestDisease {entity_id:'KG-ENT-004', name_cn:'枣缩果病', scientific_name:'Alternaria alternata / Fusarium spp.', category:'病害', description:'由真菌引起主要为害果实。果实变小皱缩果肉变褐色味苦。发病与刺吸式口器害虫有关病菌从伤口侵入。'});
MERGE (:PestDisease {entity_id:'KG-ENT-005', name_cn:'枣果腐病', scientific_name:'Botrytis cinerea / Rhizopus stolonifer', category:'病害', description:'由多种真菌引起主要为害成熟期果实。果实软化腐烂表面产生白色或灰色霉层。高温多雨暴发。'});
MERGE (:PestDisease {entity_id:'KG-ENT-006', name_cn:'枣褐斑病', scientific_name:'Cercospora spp.', category:'病害', description:'主要为害叶片出现近圆形或不规则形褐色病斑边缘明显后期中央变灰白色。'});
MERGE (:PestDisease {entity_id:'KG-ENT-007', name_cn:'枣叶黑斑病', scientific_name:'Alternaria spp.', category:'病害', description:'主要为害叶片出现黑色不规则病斑严重时叶片枯焦脱落。'});
// -- Core Pests (ENT-008 ~ ENT-015) --
