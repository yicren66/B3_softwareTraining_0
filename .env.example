# =============================================================================
# Jujube Platform — Environment Configuration Template
# Copy to .env and fill in real values. Do NOT commit .env to version control.
# =============================================================================

# --- Database: PostgreSQL ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=jujube_platform
DB_USER=jujube
DB_PASSWORD=changeme

# --- Graph Database: Neo4j ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# --- Cache / Message Broker: Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Authentication (JWT) ---
JWT_SECRET_KEY=change-me-to-random-64-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Service Registry ---
API_GATEWAY_PORT=8000
IR_SERVICE_ADDR=image-recognition:9001
KG_SERVICE_ADDR=knowledge-graph:9002
REASONING_SERVICE_ADDR=reasoning-engine:9003
MODEL_SERVICE_ADDR=model-management:9004
LOG_SERVICE_ADDR=log-statistics:9005

# --- External APIs ---
WEATHER_API_KEY=changeme
WEATHER_API_URL=https://api.weather.example.com

# --- Runtime ---
LOG_LEVEL=INFO
ENVIRONMENT=development

# --- Storage Paths ---
DATASET_PATH=/app/datasets
MODEL_REGISTRY_PATH=/app/models_registry
