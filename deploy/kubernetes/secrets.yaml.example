# =============================================================================
# Jujube Platform — Secrets Template
# COPY to secrets.yaml and fill in real values. Do NOT commit secrets.yaml.
# =============================================================================
apiVersion: v1
kind: Secret
metadata:
  name: jujube-secrets
  namespace: jujube-platform
  labels:
    app.kubernetes.io/part-of: jujube-platform
type: Opaque
stringData:
  # --- Database credentials ---
  DB_PASSWORD: "changeme"

  # --- Neo4j credentials ---
  NEO4J_PASSWORD: "changeme"

  # --- Redis (optional auth) ---
  REDIS_PASSWORD: ""

  # --- JWT signing key (generate: openssl rand -base64 64) ---
  JWT_SECRET_KEY: "change-me-to-random-64-char-string"

  # --- External API keys ---
  WEATHER_API_KEY: "changeme"

  # --- TLS certificate (optional, if using file-based TLS sidecar) ---
  # TLS_CRT: ""
  # TLS_KEY: ""
